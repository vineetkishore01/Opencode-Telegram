{
  "name": "opencode-tele",
  "version": "0.0.5",
  "description": "Telegram bot for OpenCode remote development",
  "main": "dist/index.js",
  "bin": {
    "opencode-tele": "./bin/opencode-tele.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "install-global": "npm run build && npm install -g .",
    "uninstall-global": "npm uninstall -g opencode-tele"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.0",
    "dotenv": "^16.3.1",
    "grammy": "^1.21.0",
    "undici": "^6.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "opencode",
    "telegram",
    "bot",
    "ai",
    "development"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
